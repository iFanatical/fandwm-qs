#!/bin/sh
# dwm-qs-bt — Bluetooth control for the QuickShell widget, via bluetoothctl.
# Emits key=value + tab-separated `device` rows the panel parses.
#
#   dwm-qs-bt status                 one status block
#   dwm-qs-bt watch                  status block on a poll interval (\n\n sep)
#   dwm-qs-bt power on|off
#   dwm-qs-bt scan [seconds]         timed discovery (default 8s), then rescan
#   dwm-qs-bt connect|disconnect|pair|remove|trust <MAC>
set -u

bctl() { bluetoothctl "$@" 2>/dev/null; }

emit_status() {
	powered=no
	bctl show | grep -q "Powered: yes" && powered=yes
	discovering=no
	bctl show | grep -q "Discovering: yes" && discovering=yes

	printf 'powered=%s\n' "$powered"
	printf 'discovering=%s\n' "$discovering"

	# All known devices; flag connected/paired via `info`.
	bctl devices | while read -r _kw mac name; do
		[ "$_kw" = "Device" ] || continue
		info=$(bctl info "$mac")
		conn=0; printf '%s\n' "$info" | grep -q "Connected: yes" && conn=1
		pair=0; printf '%s\n' "$info" | grep -q "Paired: yes" && pair=1
		printf 'device\t%s\t%s\t%s\t%s\n' "$mac" "$name" "$conn" "$pair"
	done
}

case "${1:-status}" in
status)
	emit_status
	;;
watch)
	interval=${2:-4}
	while :; do
		emit_status
		printf '\n'
		sleep "$interval"
	done
	;;
power)
	bctl power "${2:-on}" >/dev/null
	emit_status
	;;
scan)
	secs=${2:-8}
	# timed, non-interactive discovery; results land in `devices` afterwards
	bctl --timeout "$secs" scan on >/dev/null 2>&1 || true
	emit_status
	;;
connect | disconnect | pair | remove | trust)
	[ -n "${2:-}" ] || { printf 'usage: %s %s <MAC>\n' "$0" "$1" >&2; exit 2; }
	bctl "$1" "$2" >/dev/null 2>&1 || true
	emit_status
	;;
*)
	printf 'usage: %s [status|watch|power on|off|scan [s]|connect|disconnect|pair|remove|trust <MAC>]\n' "$0" >&2
	exit 2
	;;
esac
