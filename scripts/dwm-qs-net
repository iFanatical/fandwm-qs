#!/bin/sh
# dwm-qs-net — backend-adaptive networking for the QuickShell network widget.
#
# Backends, auto-detected:
#   nm  — NetworkManager present & running (laptop): full Wi-Fi management.
#   ip  — no NetworkManager (desktop with custom net-bridge.sh): wired/bridge/
#         VLAN status + re-apply, via iproute2.
#
# Emits key=value lines plus tab-separated rows; `watch` prints blocks
# separated by a blank line (\n\n), matching the other dwm-qs bridges.
#
#   dwm-qs-net status | watch
#   dwm-qs-net wifi-list | wifi-scan
#   dwm-qs-net wifi-connect <ssid> [password]
#   dwm-qs-net wifi-disconnect | wifi-forget <ssid> | radio on|off
#   dwm-qs-net reapply                 (ip backend: re-run net-bridge.sh)
#   dwm-qs-net link-up <if> | link-down <if>
set -u

has() { command -v "$1" >/dev/null 2>&1; }
nm_running() { has nmcli && nmcli general status >/dev/null 2>&1; }
backend() { if nm_running; then echo nm; else echo ip; fi; }

TAB=$(printf '\t')
BRIDGE_SCRIPT="${DWM_QS_NET_BRIDGE:-/usr/local/bin/net-bridge.sh}"

primary_dev() {
	ip route show default 2>/dev/null |
		awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}'
}
default_gw() {
	ip route show default 2>/dev/null | awk '{print $3; exit}'
}
wifi_dev() {
	nmcli -t -f DEVICE,TYPE device status 2>/dev/null |
		awk -F: '$2=="wifi"{print $1; exit}'
}

# ---- NetworkManager backend ------------------------------------------------

nm_status() {
	dev=$(primary_dev)
	printf 'backend=nm\n'
	printf 'wifi_enabled=%s\n' "$(nmcli -t radio wifi 2>/dev/null || echo unknown)"
	printf 'connectivity=%s\n' "$(nmcli networking connectivity 2>/dev/null || echo unknown)"
	printf 'device=%s\n' "${dev:-}"

	kind=none; name=; ip4=; gw=; ssid=; signal=; security=
	if [ -n "${dev:-}" ]; then
		while IFS=: read -r key val; do
			case "$key" in
			GENERAL.TYPE) kind=$val ;;
			GENERAL.CONNECTION) name=$val ;;
			IP4.ADDRESS*) [ -z "$ip4" ] && ip4=$val ;;
			IP4.GATEWAY) gw=$val ;;
			esac
		done <<-EOF
		$(nmcli -t -f GENERAL.TYPE,GENERAL.CONNECTION,IP4.ADDRESS,IP4.GATEWAY device show "$dev" 2>/dev/null)
		EOF
		if [ "$kind" = wifi ]; then
			ssid=$name
			signal=$(nmcli -t -f ACTIVE,SIGNAL device wifi list ifname "$dev" 2>/dev/null |
				awk -F: '$1=="yes"{print $2; exit}')
			security=$(nmcli -t -f ACTIVE,SECURITY device wifi list ifname "$dev" 2>/dev/null |
				awk -F: '$1=="yes"{print $2; exit}')
		fi
	fi
	printf 'kind=%s\n' "$kind"
	printf 'name=%s\n' "$name"
	printf 'ssid=%s\n' "$ssid"
	printf 'signal=%s\n' "$signal"
	printf 'security=%s\n' "$security"
	printf 'ip=%s\n' "$ip4"
	printf 'gateway=%s\n' "${gw:-$(default_gw)}"
}

nm_wifi_list() {
	# fields ordered so SSID (may contain ':') is last; sentinel-escape '\:'.
	nmcli -t -f IN-USE,SIGNAL,SECURITY,SSID device wifi list 2>/dev/null |
		sed 's/\\:/\x01/g' |
		awk -F: '
			{
				inuse = ($1=="*") ? 1 : 0
				signal = $2 + 0
				sec = $3
				ssid = $4; for (i = 5; i <= NF; i++) ssid = ssid ":" $i
				gsub(/\x01/, ":", ssid)
				if (ssid == "") next
				if (!(ssid in seen) || signal > sig[ssid]) {
					sig[ssid] = signal; secu[ssid] = sec; seen[ssid] = 1
				}
				if (inuse) act[ssid] = 1
			}
			END {
				for (s in seen)
					printf "%s\t%s\t%s\t%s\n", s, sig[s], secu[s], (act[s] ? 1 : 0)
			}' |
		sort -t"$TAB" -k2 -nr
}

# ---- iproute2 backend (custom bridge/VLAN desktop) -------------------------

ip_iftype() {
	# bridge | vlan | ethernet | wifi | other
	case "$1" in wlan* | wlp*) echo wifi; return ;; esac
	det=$(ip -d link show "$1" 2>/dev/null)
	case "$det" in
	*" vlan "*) echo vlan ;;
	*" bridge "*) echo bridge ;;
	*" bridge_slave "*) echo ethernet ;;
	*) echo ethernet ;;
	esac
}

ip_status() {
	printf 'backend=ip\n'
	printf 'gateway=%s\n' "$(default_gw)"
	printf 'device=%s\n' "$(primary_dev)"
	# one `link` row per interface (skip loopback)
	ip -br addr show 2>/dev/null | while read -r name state rest; do
		[ "$name" = "lo" ] && continue
		base=${name%@*}          # strip vlan parent suffix (br0.1000@br0)
		addr=$(printf '%s\n' "$rest" | awk '{print $1}')
		case "$addr" in inet6* | fe80* | "") addr="" ;; esac
		printf 'link\t%s\t%s\t%s\t%s\n' "$base" "$state" "$(ip_iftype "$base")" "$addr"
	done
}

# ---- dispatch --------------------------------------------------------------

status() { if [ "$(backend)" = nm ]; then nm_status; else ip_status; fi; }

watch() {
	status
	printf '\n'
	if [ "$(backend)" = nm ]; then
		nmcli monitor 2>/dev/null | while IFS= read -r _line; do
			status
			printf '\n'
		done
	else
		while :; do
			sleep 3
			status
			printf '\n'
		done
	fi
}

cmd=${1:-status}
case "$cmd" in
status) status ;;
watch) watch ;;
wifi-list) nm_running && nm_wifi_list ;;
wifi-scan) nm_running && nmcli device wifi rescan >/dev/null 2>&1 || true ;;
wifi-connect)
	nm_running || exit 0
	ssid=${2:-}; pass=${3:-}
	[ -n "$ssid" ] || { echo "usage: $0 wifi-connect <ssid> [password]" >&2; exit 2; }
	if [ -n "$pass" ]; then
		nmcli device wifi connect "$ssid" password "$pass" >/dev/null 2>&1 || true
	else
		nmcli device wifi connect "$ssid" >/dev/null 2>&1 || true
	fi
	status
	;;
wifi-disconnect)
	nm_running || exit 0
	dev=$(wifi_dev); [ -n "$dev" ] && nmcli device disconnect "$dev" >/dev/null 2>&1 || true
	status
	;;
wifi-forget)
	nm_running || exit 0
	[ -n "${2:-}" ] && nmcli connection delete id "$2" >/dev/null 2>&1 || true
	status
	;;
radio)
	nm_running || exit 0
	nmcli radio wifi "${2:-on}" >/dev/null 2>&1 || true
	status
	;;
reapply)
	[ -x "$BRIDGE_SCRIPT" ] && sudo -n "$BRIDGE_SCRIPT" >/dev/null 2>&1 || true
	status
	;;
link-up)
	[ -n "${2:-}" ] && sudo -n ip link set "$2" up >/dev/null 2>&1 || true
	status
	;;
link-down)
	[ -n "${2:-}" ] && sudo -n ip link set "$2" down >/dev/null 2>&1 || true
	status
	;;
*)
	echo "usage: $0 [status|watch|wifi-list|wifi-scan|wifi-connect|wifi-disconnect|wifi-forget|radio|reapply|link-up|link-down]" >&2
	exit 2
	;;
esac
